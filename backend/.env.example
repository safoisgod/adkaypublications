# ─────────────────────────────────────────
# CORE
# ─────────────────────────────────────────
SECRET_KEY=django-insecure-1234567890
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
ENVIRONMENT=development

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_NAME=publishing_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────
# EMAIL
# ─────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=Publishing House <noreply@publishinghouse.com>
ADMIN_EMAIL=admin@publishinghouse.com

# ─────────────────────────────────────────
# MEDIA / STORAGE (production: S3)
# ─────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ─────────────────────────────────────────
# SITE
# ─────────────────────────────────────────
SITE_NAME=Publishing House
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5500
